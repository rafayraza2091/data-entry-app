datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model DataEntry {
  id          Int      @id @default(autoincrement())
  book        String
  subject     String
  className   String
  edition     Int
  chapter     Int
  chapterName String
  topicNumber String
  topicName   String
  description String
  exercise    String
  page        Int
  date        String
  time        String
  school      String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BookEntry {
  id        Int      @id @default(autoincrement())
  title     String
  className String   @default("")
  subject   String
  edition   Int
  publisher String
  school    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SubjectEntry {
  id        Int      @id @default(autoincrement())
  name      String
  code      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SchoolEntry {
  id        Int      @id @default(autoincrement())
  name      String
  address   String
  branch    String
  city      String   @default("")
  code      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChapterEntry {
  id            Int      @id @default(autoincrement())
  subject       String
  book          String
  chapterNumber Int
  chapterTitle  String
  page          Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TopicEntry {
  id            Int      @id @default(autoincrement())
  subject       String
  book          String
  chapterNumber Int
  chapterName   String
  topicNumber   String
  topicName     String
  exercise      String?
  page          Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model QueryEntry {
  id             Int      @id @default(autoincrement())
  studentName    String
  teacherName    String
  className      String
  subject        String
  book           String?
  chapter        String?
  topic          String?
  exercise       String?
  questionNumber String?
  pageNumber     String?
  queryStatement String
  status         String   @default("open")
  schoolName     String   @default("")
  createdBy      String   @default("")
  images         String[] @default([])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model DataentryUser {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  firstName String   @default("")
  lastName  String   @default("")
  role      Role     @default(STUDENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("dataentryUser")
}

enum Role {
  OWNER
  COORDINATOR
  TEACHER
  ASSISTANT
  STUDENT
  PARENT
}

model Student {
  id           Int      @id @default(autoincrement())
  userId       Int?     @unique
  firstName    String
  secondName   String
  address      String
  mobileNumber String
  email          String
  fatherName     String?
  parentContact1 String?
  parentContact2 String?
  otherInfo      String?
  className      String
  schoolName     String
  status         String   @default("Active")
  subjects       String[] @default([])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Teacher {
  id           Int      @id @default(autoincrement())
  userId       Int?     @unique
  firstName    String
  secondName   String
  address      String
  mobileNumber String
  email          String
  fatherName     String?
  parentContact1 String?
  parentContact2 String?
  otherInfo      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Admin {
  id           Int      @id @default(autoincrement())
  userId       Int?     @unique
  firstName    String
  secondName   String
  address      String
  mobileNumber String
  email          String
  fatherName     String?
  parentContact1 String?
  parentContact2 String?
  otherInfo      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ClassEntry {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskEntry {
  id          Int      @id @default(autoincrement())
  createdBy   String
  className   String?
  subject     String
  book        String?
  chapter     String?
  topic       String?
  exercise    String?
  description String
  reporter    String
  assignee    String
  status      String   @default("OPEN")
  taskType    String   @default("Home Work")
  dueDate           DateTime?
  rescheduleCount   Int?
  rescheduledFromId Int?
  rescheduledToId   Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model PendingUser {
  id             Int      @id @default(autoincrement())
  firstName      String
  lastName       String
  username       String   @unique
  password       String
  email          String
  contactNumber  String
  address        String
  designation    String   @default("student")
  fatherName     String?
  parentContact1 String?
  parentContact2 String?
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
  resolvedAt     DateTime?
}

model EmployeeRecord {
  id               Int      @id @default(autoincrement())
  firstName        String
  secondName       String?
  fatherName       String?
  address          String?
  firstContact     String
  secondContact    String?
  linkedinId       String?
  status           String   @default("Pending")
  gender           String   @default("Male")
  emailAddress     String?
  dateOfBirth      String?
  latestDegree     String?
  specialization   String?
  fromDate         String?
  toDate           String?
  currentlyWorking Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Attendance {
  id          Int      @id @default(autoincrement())
  userId      Int      // References DataentryUser.id
  date        String   // Stored as YYYY-MM-DD
  status      String   @default("ABSENT") // PRESENT, ABSENT, LATE, LEAVE
  reason      String?  // Reason for absence
  markedBy    String   // Username of who initially marked it
  isLocked    Boolean  @default(false) // True when saved by Teacher/Coordinator
  isConfirmed Boolean  @default(false) // True when confirmed by Owner
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Ensure only one attendance record per user per day
  @@unique([userId, date])
}
