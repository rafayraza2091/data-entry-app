datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model DataEntry {
  id          Int      @id @default(autoincrement())
  book        String
  subject     String
  className   String
  edition     Int
  chapter     Int
  chapterName String
  topicNumber String
  topicName   String
  description String
  exercise    String
  page        Int
  date        String
  time        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BookEntry {
  id        Int      @id @default(autoincrement())
  title     String
  className String   @default("")
  subject   String
  edition   Int
  publisher String
  school    String
  page      Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SubjectEntry {
  id        Int      @id @default(autoincrement())
  name      String
  code      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SchoolEntry {
  id        Int      @id @default(autoincrement())
  name      String
  address   String
  branch    String
  city      String   @default("")
  code      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChapterEntry {
  id            Int      @id @default(autoincrement())
  subject       String
  book          String
  chapterNumber Int
  chapterTitle  String
  page          Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TopicEntry {
  id            Int      @id @default(autoincrement())
  subject       String
  book          String
  chapterNumber Int
  chapterName   String
  topicNumber   String
  topicName     String
  exercise      String?
  page          Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model DataentryUser {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  firstName String   @default("")
  lastName  String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("dataentryUser")
}
